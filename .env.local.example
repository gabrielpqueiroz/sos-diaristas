# ─── Meta Pixel (client-side, aparece no código do browser) ───────────────
NEXT_PUBLIC_META_PIXEL_ID=SEU_PIXEL_ID_AQUI

# ─── Meta CAPI (server-side, NUNCA exposto no browser) ────────────────────
META_PIXEL_ID=SEU_PIXEL_ID_AQUI
META_CAPI_ACCESS_TOKEN=SEU_TOKEN_DE_ACESSO_AQUI

# ─── Google Ads ───────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX
